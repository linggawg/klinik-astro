---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import mainBackground from "../assets/main-background.jpg";
---

<Layout title="Beranda">
	<section
		class="relative py-24 border-b border-gray-200 overflow-hidden flex items-center justify-center min-h-[80vh]"
	>
		<Image
			src={mainBackground}
			alt="Fasilitas Klinik Unpad"
			class="absolute inset-0 w-full h-full object-cover z-0"
			quality="high"
			inferSize={true}
			loading="eager"
			fetchpriority="high"
		/>

		<div class="absolute inset-0 bg-blue-900/75 z-10"></div>

		<div class="container mx-auto px-4 text-center relative z-20">
			<h1
				class="text-4xl md:text-5xl font-bold text-white mb-6 drop-shadow-md"
			>
				Layanan Kesehatan Prima <br /> Universitas Padjadjaran
			</h1>
			<p class="text-lg text-blue-50 mb-8 max-w-2xl mx-auto drop-shadow">
				Melayani civitas akademika Universitas Padjadjaran, Peserta BPJS
				Kesehatan, dan masyarakat umum dengan fasilitas modern dan
				tenaga medis profesional.
			</p>
			<a
				href="/jadwal-dokter"
				class="bg-yellow-500 hover:bg-yellow-400 text-blue-900 font-bold py-3 px-8 rounded-lg shadow-lg transition duration-300 inline-block transform hover:-translate-y-1"
			>
				Cek Jadwal Dokter
			</a>
		</div>
	</section>

	<section class="py-16 container mx-auto px-4">
		<h2 class="text-3xl font-bold text-center text-blue-800 mb-10">
			Layanan Kesehatan Utama
		</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
			<div
				class="bg-white p-6 rounded-lg shadow-sm border-t-4 border-blue-600"
			>
				<h3 class="text-xl font-bold mb-3 text-blue-900">
					Poli Umum & Gigi
				</h3>
				<p class="text-gray-600">
					Layanan preventif dan kuratif dasar untuk kesehatan Anda dan
					keluarga. Menerima pasien BPJS & Non-BPJS.
				</p>
			</div>
			<div
				class="bg-white p-6 rounded-lg shadow-sm border-t-4 border-blue-600"
			>
				<h3 class="text-xl font-bold mb-3 text-blue-900">
					Poli Spesialis
				</h3>
				<p class="text-gray-600">
					Pemeriksaan intensif oleh dokter spesialis (Penyakit Dalam,
					Mata, THT, Obgyn, Kulit & Kelamin, Jiwa, dll).
				</p>
			</div>
			<div
				class="bg-white p-6 rounded-lg shadow-sm border-t-4 border-blue-600"
			>
				<h3 class="text-xl font-bold mb-3 text-blue-900">
					Fasilitas Penunjang
				</h3>
				<p class="text-gray-600">
					Dilengkapi dengan Laboratorium Klinik, Apotek, Fisioterapi,
					Medical Check Up, hingga fasilitas Unpad Gym.
				</p>
			</div>
		</div>
	</section>
</Layout>
