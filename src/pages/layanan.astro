---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

// Data Layanan Utama
const layananUtama = [
    {
        title: "Poli Umum",
        desc: "Pelayanan kesehatan dasar bagi pasien umum dan BPJS, meliputi pemeriksaan fisik, diagnosa, dan pengobatan penyakit akut maupun kronis.",
        icon: "🩺",
    },
    {
        title: "Poli Gigi & Mulut",
        desc: "Layanan kesehatan gigi komprehensif mulai dari pembersihan karang gigi (scaling), pencabutan, penambalan, hingga estetika gigi.",
        icon: "🦷",
    },
    {
        title: "Laboratorium Klinik",
        desc: "Fasilitas pemeriksaan darah, urin, dan cairan tubuh lainnya untuk mendukung diagnosa medis yang akurat dan cepat.",
        icon: "🔬",
    },
];

// Data Poli Spesialis
const poliSpesialis = [
    "Penyakit Dalam",
    "Kesehatan Anak",
    "Kebidanan & Kandungan (Obgyn)",
    "Mata",
    "Telinga Hidung Tenggorok (THT)",
    "Kulit & Kelamin",
    "Kesehatan Jiwa",
    "Saraf",
    "Bedah Umum",
];

// Data Fasilitas Khusus
const fasilitasKhusus = [
    {
        title: "Unpad Gym & Fitness",
        desc: "Pusat kebugaran modern yang terbuka untuk mahasiswa, staf Unpad, dan masyarakat umum dengan instruktur berpengalaman.",
        image: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=800&auto=format&fit=crop",
    },
    {
        title: "Fisioterapi",
        desc: "Layanan rehabilitasi fisik untuk pemulihan cedera olahraga, pasca operasi, atau gangguan gerak fungsional lainnya.",
        image: "https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=800&auto=format&fit=crop",
    },
];
---

<Layout title="Layanan Medis">
    <section class="bg-blue-900 text-white py-20">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-bold mb-4">
                Layanan Medis Terpadu
            </h1>
            <p class="text-blue-100 max-w-2xl mx-auto text-lg">
                Kami menghadirkan berbagai poli klinis dan fasilitas penunjang
                kesehatan untuk memastikan Anda mendapatkan perawatan terbaik di
                satu tempat.
            </p>
        </div>
    </section>

    <section class="py-16 container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                layananUtama.map((item) => (
                    <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                        <div class="text-4xl mb-4">{item.icon}</div>
                        <h3 class="text-2xl font-bold text-blue-900 mb-3">
                            {item.title}
                        </h3>
                        <p class="text-gray-600 leading-relaxed">{item.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="bg-gray-100 py-16">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row gap-12 items-start">
                <div class="md:w-1/3">
                    <h2
                        class="text-3xl font-bold text-blue-900 mb-6 border-l-4 border-yellow-500 pl-4"
                    >
                        Poli Spesialis
                    </h2>
                    <p class="text-gray-600 mb-6">
                        Pemeriksaan mendalam oleh dokter spesialis ahli untuk
                        berbagai keluhan kesehatan spesifik Anda.
                    </p>
                    <a
                        href="/jadwal-dokter"
                        class="text-blue-700 font-bold hover:underline flex items-center gap-2"
                    >
                        Lihat Jadwal Dokter Spesialis &rarr;
                    </a>
                </div>
                <div
                    class="md:w-2/3 bg-white p-8 rounded-2xl shadow-sm grid grid-cols-1 sm:grid-cols-2 gap-4"
                >
                    {
                        poliSpesialis.map((poli) => (
                            <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg text-blue-900 font-medium italic">
                                <span class="text-yellow-500">✔</span> {poli}
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="py-16 container mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-blue-900 mb-12">
            Kebugaran & Rehabilitasi
        </h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            {
                fasilitasKhusus.map((fasil) => (
                    <div class="group relative overflow-hidden rounded-2xl shadow-lg aspect-video lg:aspect-auto lg:h-[400px]">
                        <Image
                            src={fasil.image}
                            alt={fasil.title}
                            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            inferSize={true}
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-blue-950 via-transparent to-transparent opacity-90" />
                        <div class="absolute bottom-0 p-8 text-white">
                            <h3 class="text-3xl font-bold mb-2">
                                {fasil.title}
                            </h3>
                            <p class="text-blue-100 max-w-md">{fasil.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="py-16 container mx-auto px-4 text-center">
        <div class="bg-yellow-500 rounded-3xl p-10 md:p-16">
            <h2 class="text-3xl md:text-4xl font-bold text-blue-950 mb-6">
                Butuh Konsultasi Lebih Lanjut?
            </h2>
            <p class="text-blue-900 mb-8 max-w-xl mx-auto font-medium">
                Hubungi kami melalui WhatsApp untuk pendaftaran pasien baru atau
                informasi tarif layanan Medical Check Up (MCU).
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="https://wa.me/6285792708050"
                    class="bg-blue-950 text-white font-bold py-4 px-10 rounded-xl hover:bg-blue-900 transition-colors shadow-lg"
                >
                    Hubungi via WhatsApp
                </a>
                <a
                    href="/informasi"
                    class="bg-white text-blue-950 font-bold py-4 px-10 rounded-xl hover:bg-gray-100 transition-colors border border-blue-900/10"
                >
                    Informasi Tarif & MCU
                </a>
            </div>
        </div>
    </section>
</Layout>
