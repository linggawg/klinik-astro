---
// src/pages/artikel/index.astro
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Mengambil semua artikel dan mengurutkan dari yang terbaru
const semuaArtikel = await getCollection("artikel");
const artikelTerbaru = semuaArtikel.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<Layout title="Artikel & Edukasi Kesehatan">
    <section class="bg-blue-900 text-white py-16">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl font-bold mb-4">Portal Edukasi & Berita</h1>
            <p class="text-blue-100 max-w-2xl mx-auto text-lg">
                Dapatkan informasi kesehatan terpercaya, tips gaya hidup sehat,
                dan pengumuman terbaru dari Klinik Universitas Padjadjaran.
            </p>
        </div>
    </section>

    <section class="py-16 container mx-auto px-4 min-h-[50vh]">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                artikelTerbaru.map((post) => (
                    <a
                        href={`/artikel/${post.slug}`}
                        class="group flex flex-col bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
                    >
                        {post.data.image ? (
                            <div class="h-48 overflow-hidden bg-gray-200">
                                <img
                                    src={post.data.image}
                                    alt={post.data.title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                />
                            </div>
                        ) : (
                            <div class="h-48 bg-blue-100 flex items-center justify-center">
                                <span class="text-blue-300 text-5xl">📄</span>
                            </div>
                        )}

                        <div class="p-6 flex flex-col flex-grow">
                            <span class="text-xs font-bold text-blue-800 bg-blue-50 px-3 py-1 rounded-full w-fit mb-3">
                                {post.data.category}
                            </span>
                            <h2 class="text-xl font-bold mb-3 text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2">
                                {post.data.title}
                            </h2>
                            <p class="text-gray-600 text-sm mb-4 line-clamp-3 flex-grow">
                                {post.data.description}
                            </p>
                            <div class="pt-4 border-t border-gray-100 flex justify-between items-center text-xs text-gray-500 mt-auto">
                                <span class="font-medium">
                                    {post.data.author}
                                </span>
                                <time
                                    datetime={post.data.publishDate.toISOString()}
                                >
                                    {post.data.publishDate.toLocaleDateString(
                                        "id-ID",
                                        {
                                            year: "numeric",
                                            month: "short",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>
</Layout>
