---
const currentYear = new Date().getFullYear();
---

<footer
    class="bg-blue-950 text-gray-300 pt-16 pb-8 border-t-4 border-yellow-500 mt-auto"
>
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
            <div>
                <h3
                    class="text-white text-xl font-bold mb-4 flex items-center gap-2"
                >
                    <span class="text-yellow-400">+</span> Klinik Unpad
                </h3>
                <p class="text-sm leading-relaxed mb-4">
                    Memberikan pelayanan kesehatan paripurna bagi civitas
                    akademika Universitas Padjadjaran dan masyarakat umum dengan
                    fasilitas modern dan tenaga medis profesional.
                </p>
            </div>

            <div>
                <h4
                    class="text-white font-semibold mb-4 border-b border-blue-800 pb-2 inline-block"
                >
                    Tautan Cepat
                </h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="/"
                            class="hover:text-yellow-400 transition-colors"
                            >Beranda</a>
                    </li>
                    <li>
                        <a
                            href="/layanan"
                            class="hover:text-yellow-400 transition-colors"
                            >Layanan Medis</a>
                    </li>
                    <li>
                        <a
                            href="/jadwal-dokter"
                            class="hover:text-yellow-400 transition-colors"
                            >Jadwal Praktek Dokter</a>
                    </li>
                    <li>
                        <a
                            href="/informasi"
                            class="hover:text-yellow-400 transition-colors"
                            >Informasi & Tarif</a>
                    </li>
                    <li>
                        <a
                            href="/artikel"
                            class="hover:text-yellow-400 transition-colors"
                            >Artikel & Edukasi</a>
                    </li>
                </ul>
            </div>

            <div>
                <h4
                    class="text-white font-semibold mb-4 border-b border-blue-800 pb-2 inline-block"
                >
                    Kontak & Lokasi
                </h4>
                <ul class="space-y-4 text-sm">
                    <li class="flex items-start gap-3">
                        <svg
                            class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                        <span
                            ><strong>Klinik Jatinangor:</strong><br />Gedung UKM
                            Barat Unpad Jatinangor</span
                        >
                    </li>
                    <li class="flex items-start gap-3">
                        <svg
                            class="w-5 h-5 text-yellow-400 shrink-0 mt-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                        <span
                            ><strong>Klinik Dipatiukur:</strong><br />Jl.
                            Dipatiukur No. 46, Bandung</span
                        >
                    </li>
                    <li class="flex items-center gap-3">
                        <svg
                            class="w-5 h-5 text-yellow-400 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path></svg
                        >
                        <span>Telp / WA: 08xx-xxxx-xxxx</span>
                    </li>
                </ul>
            </div>

            <div>
                <h4
                    class="text-white font-semibold mb-4 border-b border-blue-800 pb-2 inline-block"
                >
                    Jam Layanan
                </h4>
                <ul class="space-y-2 text-sm">
                    <li
                        class="flex justify-between border-b border-blue-900 pb-1"
                    >
                        <span>Senin - Jumat</span>
                        <span class="text-white">08:00 - 16:00 WIB</span>
                    </li>
                    <li
                        class="flex justify-between border-b border-blue-900 pb-1"
                    >
                        <span>Sabtu</span>
                        <span class="text-white">08:00 - 12:00 WIB</span>
                    </li>
                    <li class="flex justify-between pb-1 text-red-400">
                        <span>Minggu & Libur Nasional</span>
                        <span>Tutup</span>
                    </li>
                    <li class="mt-4 pt-4 border-t border-blue-800">
                        <span class="block text-yellow-400 font-bold mb-1"
                            >Pusat Informasi</span
                        >
                        <span class="text-white font-medium"
                            >Buka pada jam kerja</span
                        >
                    </li>
                </ul>
            </div>
        </div>

        <div
            class="pt-8 border-t border-blue-900 flex flex-col md:flex-row justify-between items-center gap-4 text-xs"
        >
            <p>
                &copy; {currentYear} Klinik Kesehatan Universitas Padjadjaran. Hak
                Cipta Dilindungi.
            </p>
            <div class="flex gap-4">
                <a href="#" class="hover:text-white transition-colors"
                    >Instagram</a
                >
                <a href="#" class="hover:text-white transition-colors"
                    >Facebook</a
                >
                <a href="#" class="hover:text-white transition-colors"
                    >Twitter</a
                >
            </div>
        </div>
    </div>
</footer>
